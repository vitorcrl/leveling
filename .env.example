# Copie para .env e preencha com valores reais. Nunca commitar .env.

# --- Banco de dados ---
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/bot_db

# --- Claude API ---
# USE_AI_NARRATOR=false usa TemplateNarrator (zero custo, zero chave necessária).
ANTHROPIC_API_KEY=
USE_AI_NARRATOR=false

# --- Telegram ---
TELEGRAM_BOT_TOKEN=

# --- brapi.dev ---
BRAPI_TOKEN=

